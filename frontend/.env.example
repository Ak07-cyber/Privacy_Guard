# PassiveGuard Frontend SDK Configuration
# Copy this file to .env and fill in your values

# API Configuration
REACT_APP_PASSIVEGUARD_API=http://localhost:8000
VITE_PASSIVEGUARD_API=http://localhost:8000

# Site Configuration
REACT_APP_PASSIVEGUARD_SITE_KEY=your-site-key-here
VITE_PASSIVEGUARD_SITE_KEY=your-site-key-here

# Debug Mode (set to 'true' for development)
REACT_APP_DEBUG=false
VITE_DEBUG=false
