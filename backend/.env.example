# PassiveGuard Backend Configuration
# Copy this file to .env and fill in your values

# Security
PASSIVEGUARD_SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=development

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ML Model Configuration
MODEL_PATH=./models/bot_detector.joblib
CONFIDENCE_THRESHOLD=0.7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database (if needed in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/passiveguard
# REDIS_URL=redis://localhost:6379/0
